# --- Google Sign-In (pick one path) ---
#
# Option A — Mocha Users Service (apps created on getmocha.com):
# MOCHA_USERS_SERVICE_API_URL=
# MOCHA_USERS_SERVICE_API_KEY=
# In Mocha app settings, allow redirect URL: http://localhost:5173/auth/callback (and your prod URL).
#
# Option B — Direct Google OAuth (Google Cloud Console):
# Create OAuth 2.0 Web client → Authorized redirect URIs (each must match EXACTLY):
#   http://localhost:5173/auth/callback
#   http://127.0.0.1:5173/auth/callback
#   https://<your-workers-subdomain>.workers.dev/auth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Used when MOCHA_USERS_SERVICE_API_KEY is empty. Run: npm run db:migrate:local
#
# Production: set this to your live app URL (no trailing slash) if needed:
# PUBLIC_APP_URL=https://your-app.workers.dev
# OAUTH_REDIRECT_URI=https://your-app.workers.dev/auth/callback
#
MOCHA_USERS_SERVICE_API_URL=
MOCHA_USERS_SERVICE_API_KEY=
#
# --- Email/password password reset (Resend, no-reply) ---
# Get a key at https://resend.com/api-keys (must start with re_ and be a real key — not re_xxxxxxxx).
# Local: paste into .dev.vars and restart `npm run dev` / `wrangler dev`.
# Production: npx wrangler secret put RESEND_API_KEY
# RESEND_API_KEY=re_your_real_key_here
#
# Sandbox (no custom domain): omit TRANSACTIONAL_EMAIL_FROM — defaults to onboarding@resend.dev
# (Resend only delivers to the email on your Resend account until you verify a domain).
# Production: npx wrangler secret put TRANSACTIONAL_EMAIL_FROM
# TRANSACTIONAL_EMAIL_FROM=FEEDBACK <no-reply@yourdomain.com>
#
# Without a valid RESEND_API_KEY, local dev (localhost / redirect_base) logs the reset link in the Worker console.
# PUBLIC_APP_URL=http://localhost:5173
# JamBase Data API v3 — Worker→JamBase requests use Cloudflare edge cache (see jambase-client.ts TTLs).
# Get a key from https://data.jambase.com — paste the raw token only (no "Bearer", no quotes).
# If venue resolve says HTTP 401/403: key is wrong, expired, or not loaded (restart `wrangler dev` after editing .dev.vars).
# Optional D1 cap on **upstream** calls only (cache HITs do not count). Apply migration 42.sql.
# For local debugging, leave quota OFF unless you need it:  JAMBASE_QUOTA_ENFORCEMENT=0
# Example 6k/month: JAMBASE_QUOTA_ENFORCEMENT=1  JAMBASE_QUOTA_MAX=6000  JAMBASE_QUOTA_WINDOW=month
# All-time cap instead: omit JAMBASE_QUOTA_WINDOW or set JAMBASE_QUOTA_WINDOW=all
# Per-IP caps also apply to /api/jambase/* and /api/search/advanced.
JAMBASE_API_KEY=
# Music recognition for capture / POST /api/clips/identify-music (ACRCloud preferred).
# From https://console.acrcloud.com/ → Audio & Video Recognition project → keys: Host, Access Key, Access Secret.
# REQUIRED: attach the "ACRCloud Music" bucket to that project (Project → Buckets). A custom-only or empty
# bucket returns code 1001 ("No result") on every request even though the API dashboard shows activity.
# Host is like identify-eu-west-1.acrcloud.com (no https://).
# LOCAL DEV: all three must be non-empty in .dev.vars (wrangler secret put is production only).
# Verify while logged in: GET /api/clips/identify-music/config → activeProvider "acrcloud", ready true.
# ACRCLOUD_HOST=identify-us-west-2.acrcloud.com
# ACRCLOUD_ACCESS_KEY=your_key_here
# ACRCLOUD_ACCESS_SECRET=your_secret_here
# Optional AudD fallback (https://docs.audd.io/) if ACRCloud is not set:
# AUDD_API_TOKEN=
# YouTube Data API v3 — home feed carousels for favorite artists (Google Cloud → enable API → API key).
# Use a server key with API restriction "YouTube Data API v3" only (not HTTP referrer restriction).
# Worker caches responses at the edge + in D1 (migration 50.sql) to cut quota use.
# Default project quota is 10,000 units/day (search.list = 100 units). Recommended local:
#   YOUTUBE_QUOTA_ENFORCEMENT=1
#   YOUTUBE_QUOTA_MAX=9500
# Local: set here. Production: wrangler secret put YOUTUBE_API_KEY
# YOUTUBE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
TICKETMASTER_API_KEY=
GOOGLE_MAPS_API_KEY=
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/momentum
