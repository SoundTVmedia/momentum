# --- Mocha (Google + Spotify OAuth) ---
# Required for OAuth: API URL + key from your Mocha / GetMocha project.
# Local + Cloudflare: same vars in .dev.vars (local) and wrangler secret / dashboard (prod).
MOCHA_USERS_SERVICE_API_URL=
MOCHA_USERS_SERVICE_API_KEY=
# Optional: if Mocha cannot infer return URL, set your app origin (e.g. http://localhost:5173 or https://your-domain.com).
# The app normally sends ?redirect_base= automatically from the browser.
# MOCHA_OAUTH_REDIRECT_ORIGIN=
#
# In your Mocha app settings, allow OAuth return to this app, e.g.:
#   http://localhost:5173/auth/callback
#   http://localhost:5173/auth   (some flows land ?code= here)
#   https://<your-workers-or-pages-domain>/auth/callback
# Spotify: enable Spotify for the project in Mocha if the provider is supported there.
#
# --- Email/password password reset (Resend) ---
# Optional: without RESEND_API_KEY, local dev still works — the Worker logs the reset URL when the request is from a local host.
# RESEND_API_KEY=
# Use a verified sender in Resend (default onboarding@resend.dev only works for Resend test domain).
# TRANSACTIONAL_EMAIL_FROM=Momentum <onboarding@resend.dev>
# If the Worker cannot infer your SPA origin, set the public app URL (password reset links).
# PUBLIC_APP_URL=http://localhost:5173
# JamBase Data API v3 — Worker→JamBase requests use Cloudflare edge cache (see jambase-client.ts TTLs).
# Get a key from https://data.jambase.com — paste the raw token only (no "Bearer", no quotes).
# If venue resolve says HTTP 401/403: key is wrong, expired, or not loaded (restart `wrangler dev` after editing .dev.vars).
# Optional D1 cap on **upstream** calls only (cache HITs do not count). Apply migration 42.sql.
# For local debugging, leave quota OFF unless you need it:  JAMBASE_QUOTA_ENFORCEMENT=0
# Example 6k/month: JAMBASE_QUOTA_ENFORCEMENT=1  JAMBASE_QUOTA_MAX=6000  JAMBASE_QUOTA_WINDOW=month
# All-time cap instead: omit JAMBASE_QUOTA_WINDOW or set JAMBASE_QUOTA_WINDOW=all
# Per-IP caps also apply to /api/jambase/* and /api/search/advanced.
JAMBASE_API_KEY=
# Optional — AudD music recognition (https://docs.audd.io/). Used by POST /api/clips/identify-music.
# AUDD_API_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
TICKETMASTER_API_KEY=
GOOGLE_MAPS_API_KEY=
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/momentum
