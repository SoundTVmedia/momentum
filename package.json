{
  "name": "mocha-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "@capacitor-community/media": "^8.0.1",
    "@capacitor/android": "^7.6.6",
    "@capacitor/core": "^7.6.6",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/ios": "^7.6.6",
    "@capacitor/push-notifications": "^7.0.6",
    "@hono/zod-validator": "^0.5.0",
    "aws4fetch": "^1.0.20",
    "hls.js": "^1.6.16",
    "hono": "^4.12.15",
    "lucide-react": "^0.510.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-is": "19.0.0",
    "react-router": "^7.5.3",
    "recharts": "^3.4.1",
    "stripe": "^19.3.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.6",
    "@cloudflare/vite-plugin": "^1.2.4",
    "@eslint/js": "9.25.1",
    "@getmocha/users-service": "^0.0.4",
    "@getmocha/vite-plugins": "latest",
    "@types/node": "22.14.1",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.19",
    "globals": "15.15.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "5.8.3",
    "typescript-eslint": "8.31.0",
    "vite": "^7.1.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.87.0"
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "build:worker": "ENABLE_CLOUDFLARE_VITE=1 npm run build",
    "deploy": "ENABLE_CLOUDFLARE_VITE=1 npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "check": "ENABLE_CLOUDFLARE_VITE=1 tsc && vite build && wrangler deploy --dry-run",
    "dev": "node scripts/dev.mjs",
    "dev:worker": "vite",
    "db:migrate:local": "wrangler d1 migrations apply momentum-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply momentum-db --remote",
    "dev:api": "wrangler dev",
    "dev:api:remote": "wrangler dev --remote",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync": "npm run build && npx cap sync",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  }
}
